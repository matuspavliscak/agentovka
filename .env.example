# Agentovka configuration — copy to .env (never commit real credentials).
# All configuration is via environment variables; credentials are never passed
# as MCP tool parameters.

# ISDS login credentials (username + password for your data box).
ISDS_USERNAME=your-test-username
ISDS_PASSWORD=your-test-password

# Environment: test | production. Default is test on purpose — do not switch to
# production until you understand the legal consequences of each tool.
ISDS_ENV=test

# Where the local archive is stored (original ZFO + attachments + metadata).
AGENTOVKA_ARCHIVE_DIR=~/.agentovka/archive

# Sending is a legal act. Real sending requires BOTH dry_run=false on the tool
# call AND this flag set to true. Default is false.
AGENTOVKA_ALLOW_SEND=false
